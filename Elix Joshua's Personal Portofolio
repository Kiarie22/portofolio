</html>:root {
  --primary-color: #2c3e50;
  --accent-color: #3498db;
  --text-color: #333;
}

body {
  font-family: Arial, sans-serif;
  margin: 0;
  padding: 0;
  color: var(--text-color);
}

header, footer {
  background: var(--primary-color);
  color: white;
  text-align: center;
  padding: 1em;
}

nav ul {
  list-style: none;
  display: flex;
  justify-content: center;
  gap: 20px;
}

nav a {
  color: white;
  text-decoration: none;
}

.hero {
  text-align: center;
  padding: 50px;
}

.btn {
  background: var(--accent-color);
  color: white;
  padding: 10px 20px;
  margin: 10px;
  text-decoration: none;
  border-radius: 5px;
}

.projects {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  padding: 20px;
}

.card {
  border: 1px solid #ccc;
  padding: 15px;
  border-radius: 8px;
}

form {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 20px;
}

@media (max-width: 600px) {
  nav ul {
    flex-direction: column;
  }
}
